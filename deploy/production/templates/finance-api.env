APP_ENV=production
HTTP_HOST=127.0.0.1
HTTP_PORT=8080
DATABASE_URL_FILE=/etc/finance/secrets/database-url
FRONTEND_ORIGINS=https://__FINANCE_DOMAIN__
AUTH_ISSUER=https://__SUPABASE_HOST__/auth/v1
AUTH_AUDIENCE=authenticated
AUTH_JWKS_URL=https://__SUPABASE_HOST__/auth/v1/.well-known/jwks.json
AUTH_JWKS_CACHE_TTL=10m
AUTH_JWKS_REFRESH_COOLDOWN=30s
AUTH_CLOCK_SKEW=30s
AUTH_JWKS_HTTP_TIMEOUT=2s
PRODUCTION_SECURITY_PROFILE=single-proxy-single-replica-v1
PRODUCTION_SECURITY_ACK=ack-single-proxy-single-replica-v1
API_REPLICA_COUNT=1
IMPORT_BACKUP_V5_ENABLED=false
IMPORT_HMAC_ACTIVE_KEY_ID=__IMPORT_ACTIVE_KEY_ID__
IMPORT_HMAC_KEYRING_FILE=/etc/finance/secrets/import-hmac-keyring.json
IMPORT_PRODUCTION_ACK=
