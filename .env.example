# Новый Go API
APP_ENV=development
HTTP_HOST=127.0.0.1
HTTP_PORT=8080
DATABASE_URL=postgres://finance:finance_dev_only@127.0.0.1:5432/finance_dev?sslmode=disable
# В production DATABASE_URL запрещен; используется owner-only absolute file:
DATABASE_URL_FILE=
FRONTEND_ORIGINS=http://127.0.0.1:5173
AUTH_ISSUER=https://your-project-ref.supabase.co/auth/v1
AUTH_AUDIENCE=authenticated
AUTH_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
AUTH_JWKS_CACHE_TTL=10m
AUTH_JWKS_REFRESH_COOLDOWN=30s
AUTH_CLOCK_SKEW=30s
AUTH_JWKS_HTTP_TIMEOUT=2s
API_REPLICA_COUNT=1
# Production values задаются только после render/verification из deploy/production:
PRODUCTION_SECURITY_PROFILE=
PRODUCTION_SECURITY_ACK=
IMPORT_BACKUP_V5_ENABLED=false
# Используются только при явно разрешенном включении импорта:
IMPORT_HMAC_ACTIVE_KEY_ID=replace-with-stable-key-id
IMPORT_HMAC_KEYRING_FILE=/absolute/path/to/import-hmac-keyring.json
IMPORT_PRODUCTION_ACK=

# Новый Vite frontend
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://127.0.0.1:8080
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Локальный PostgreSQL из deploy/compose.yaml
POSTGRES_DB=finance_dev
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance_dev_only
POSTGRES_PORT=5432
